{
  "id": "pack-core",
  "version": "2.0.0",
  "schemaVersion": "1.0.0",
  "source": "LOCAL",
  "compatibility": {
    "apiRange": "1.x",
    "engineRange": "1.x",
    "kotlinRange": "2.3.x",
    "gradleRange": "8.x"
  },
  "templates": [
    {
      "id": "android-app",
      "displayName": "Android App",
      "description": "Android-only multi-module starter",
      "version": "2.0.0",
      "tags": ["android", "gradle", "wizard"],
      "baseOptionIds": ["base-kotlin", "build-gradle-kts", "target-android"]
    }
  ],
  "options": [
    {
      "id": "base-kotlin",
      "type": "BASE",
      "category": "base",
      "displayName": "Kotlin Base",
      "description": "Core Kotlin settings and generator metadata",
      "defaultEnabled": true,
      "dependency": {
        "requiresOptionIds": [],
        "requiresCapabilities": [],
        "providesCapabilities": ["lang:kotlin"],
        "conflictsHard": []
      },
      "version": {
        "recommended": "2.3.0",
        "supported": ["2.3.0"],
        "range": "2.x"
      },
      "parameters": [
        {
          "id": "explicitApiMode",
          "displayName": "Explicit API Mode",
          "description": "Explicit API policy for generated Kotlin modules.",
          "type": "ENUM",
          "defaultValue": "warning",
          "allowedValues": [
            { "value": "disabled", "displayName": "Disabled" },
            { "value": "warning", "displayName": "Warning" },
            { "value": "strict", "displayName": "Strict" }
          ]
        },
        {
          "id": "enableContextParameters",
          "displayName": "Enable Context Parameters",
          "description": "Enable Kotlin context parameters in generated Gradle settings.",
          "type": "BOOLEAN",
          "defaultValue": "false"
        },
        {
          "id": "optInAnnotations",
          "displayName": "Opt-In Annotations",
          "description": "Comma or newline separated opt-in annotations.",
          "type": "MULTILINE",
          "defaultValue": "kotlinx.coroutines.ExperimentalCoroutinesApi"
        }
      ],
      "patches": [
        {
          "type": "ADD_FILE",
          "targetPath": ".wizard/kotlin/settings.properties",
          "content": "kotlin.package=${Package}\nkotlin.explicitApiMode=${Param.explicitApiMode}\nkotlin.enableContextParameters=${Param.enableContextParameters}\nkotlin.optInAnnotations=${Param.optInAnnotations}\n",
          "conflictStrategy": "MERGE_WITH_RULE"
        }
      ]
    },
    {
      "id": "build-gradle-kts",
      "type": "BUILD_SYSTEM",
      "category": "build",
      "displayName": "Gradle Kotlin DSL",
      "description": "Gradle build using Kotlin DSL and convention plugins",
      "defaultEnabled": true,
      "dependency": {
        "requiresOptionIds": ["base-kotlin"],
        "requiresCapabilities": ["lang:kotlin"],
        "providesCapabilities": ["build:gradle-kts"],
        "conflictsHard": []
      },
      "version": {
        "recommended": "8.14.3",
        "supported": ["8.14.3"],
        "range": "8.x"
      }
    }
  ]
}
