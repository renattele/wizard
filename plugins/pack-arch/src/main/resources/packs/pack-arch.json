{
  "id": "pack-arch",
  "version": "2.0.0",
  "schemaVersion": "1.0.0",
  "source": "LOCAL",
  "compatibility": {
    "apiRange": "1.x",
    "engineRange": "1.x",
    "kotlinRange": "2.3.x",
    "gradleRange": "8.x"
  },
  "options": [
    {
      "id": "arch-mvvm",
      "type": "ARCHITECTURE",
      "category": "architecture",
      "displayName": "MVVM",
      "description": "Presentation, state, and view model boilerplate",
      "defaultEnabled": true,
      "dependency": {
        "requiresOptionIds": [],
        "requiresCapabilities": ["ui:framework"],
        "providesCapabilities": ["arch:mvvm"],
        "conflictsHard": ["arch-mvi", "arch-mvp"]
      },
      "version": {
        "recommended": "1.0.0",
        "supported": ["1.0.0"],
        "range": "1.x"
      },
      "parameters": [
        {
          "id": "viewModelSuffix",
          "displayName": "ViewModel suffix",
          "description": "Suffix for generated view models.",
          "type": "STRING",
          "required": true,
          "defaultValue": "ViewModel"
        }
      ]
    },
    {
      "id": "arch-mvi",
      "type": "ARCHITECTURE",
      "category": "architecture",
      "displayName": "MVI",
      "description": "Intent, state, reducer-style boilerplate",
      "dependency": {
        "requiresOptionIds": [],
        "requiresCapabilities": ["ui:framework"],
        "providesCapabilities": ["arch:mvi"],
        "conflictsHard": ["arch-mvvm", "arch-mvp"]
      },
      "version": {
        "recommended": "1.0.0",
        "supported": ["1.0.0"],
        "range": "1.x"
      }
    },
    {
      "id": "arch-mvp",
      "type": "ARCHITECTURE",
      "category": "architecture",
      "displayName": "MVP",
      "description": "Presenter and contract boilerplate",
      "dependency": {
        "requiresOptionIds": [],
        "requiresCapabilities": ["ui:framework"],
        "providesCapabilities": ["arch:mvp"],
        "conflictsHard": ["arch-mvvm", "arch-mvi"]
      },
      "version": {
        "recommended": "1.0.0",
        "supported": ["1.0.0"],
        "range": "1.x"
      }
    }
  ]
}
