{
  "id": "pack-android",
  "version": "2.0.0",
  "schemaVersion": "1.0.0",
  "source": "LOCAL",
  "compatibility": {
    "apiRange": "1.x",
    "engineRange": "1.x",
    "kotlinRange": "2.3.x",
    "gradleRange": "8.x"
  },
  "options": [
    {
      "id": "target-android",
      "type": "BASE",
      "category": "target",
      "displayName": "Android Target",
      "description": "Android application and shared core module skeleton",
      "defaultEnabled": true,
      "dependency": {
        "requiresOptionIds": ["base-kotlin", "build-gradle-kts"],
        "requiresCapabilities": ["lang:kotlin", "build:gradle-kts"],
        "providesCapabilities": ["target:android"],
        "conflictsHard": []
      },
      "version": {
        "recommended": "35",
        "supported": ["34", "35"],
        "range": null
      },
      "patches": [
        {
          "type": "ADD_TEMPLATE_DIRECTORY",
          "targetPath": "",
          "resourcePath": "packs/templates/android-base",
          "conflictStrategy": "MERGE_WITH_RULE"
        }
      ]
    }
  ]
}
