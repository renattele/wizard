      "id": "library-retrofit",
      "type": "LIBRARY",
      "category": "network",
      "displayName": "Retrofit + OkHttp",
      "description": "Classic HTTP client stack in `core:network` with Retrofit service interfaces and OkHttp logging.",
      "dependency": {
        "requiresOptionIds": ["target-android"],
        "requiresCapabilities": ["target:android"],
        "providesCapabilities": ["library:retrofit", "network:http-client", "network:retrofit"],
        "conflictsHard": ["library-ktor-client"]
      },
      "version": {
        "recommended": "2.11.0",
        "supported": ["2.11.0"],
        "range": "2.x"
      },
      "validation": {
        "compileAffecting": true,
        "exclusiveGroup": "network-stack"
      },
      "patches": [
        {
          "type": "ADD_TEMPLATE_DIRECTORY",
          "targetPath": "",
          "resourcePath": "packs/templates/libraries/retrofit",
          "conflictStrategy": "MERGE_WITH_RULE"
        },
        {
          "type": "REPLACE_IN_FILE",
          "targetPath": "core/network/build.gradle.kts",
          "find": "// __CORE_NETWORK_DEPENDENCY_MARKER__",
          "replace": "    api(libs.retrofit)\n    api(libs.okhttp)\n    implementation(libs.okhttp.logging)\n    // __CORE_NETWORK_DEPENDENCY_MARKER__",
          "conflictStrategy": "MERGE_WITH_RULE"
        }
      ]
    },
